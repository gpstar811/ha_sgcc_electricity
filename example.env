### 以下项都需要修改
## 国网登录信息
# 修改为自己的登录账号
PHONE_NUMBER="xxx" 
# 修改为自己的登录密码
PASSWORD="xxxx" 
# 排除指定用户ID，如果出现一些不想检测的ID或者有些充电、发电帐号、可以使用这个环境变量，如果有多个就用","分隔，","之间不要有空格
IGNORE_USER_ID=xxxxxxx,xxxxxxx,xxxxxxx

## 数据库配置
# DB_TYPE 数据储存类型 sqlite / mysql，默认为 NONE 不进行数据储存
DB_TYPE=NONE

# sqlite 数据库名，默认为 homeassistant.db
DB_NAME="homeassistant.db"

# mysql 的数据库配置
MYSQL_HOST="mysql.lan"
MYSQL_USER="user"
MYSQL_PASSWORD="password"
MYSQL_DATABASE="sgcc"
MYSQL_PORT=3306

# 数据库记录保留天数，默认 365 天（1年），设为 0 则永久保留
DATA_RETENTION_DAYS=365

# 每日用电量获取天数，支持 7 或 30（通过 radio 按钮切换即可）
DAILY_FETCH_DAYS=7

## homeassistant配置
# 改为你的localhost为你的homeassistant地址
HASS_URL="http://localhost:8123/" 
# homeassistant的长期令牌
HASS_TOKEN="eyxxxxx"

## selenium运行参数
# 登录方式: password / qrcode
# password: 使用账号密码登录（默认）
# qrcode: 直接扫码登录，测试时无需输入密码，打开后会弹出二维码
LOGIN_METHOD="password"
# 任务开始时间，24小时制，例如"07:00"则为每天早上7点执行，每隔12小时执行一次。
JOB_START_TIME="07:00"
# Docker 启动后立即登录抓取（不等待 JOB_START_TIME，忽略缓存）。调试或首次部署建议设为 true
RUN_ON_STARTUP="false"
# 每次操作等待时间，推荐设定范围为[2,30]，该值表示每次点击网页后所要等待数据加载的时间
RETRY_WAIT_TIME_OFFSET_UNIT=15

## 验证码识别
# CAPTCHA_SOLVER: local（本地 OCR/图像匹配，默认）| llm（火山引擎豆包大模型，支持点击+滑块）
CAPTCHA_SOLVER="local"
# 火山引擎 ARK API Key（CAPTCHA_SOLVER=llm 时必填）
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=""
# 大模型名称（可选）
# ARK_MODEL="doubao-seed-2-0-pro-260215"
# ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

## 浏览器反检测参数（可选）
# BROWSER_LANGUAGE=zh-HK,zh,en-US,en,zh-CN
# BROWSER_WINDOW_SIZE=1158,848
# BROWSER_DEVICE_SCALE_FACTOR=2
# BROWSER_USER_AGENT=
# BROWSER_NAV_PLATFORM=Linux x86_64

## 本地点选验证码调参（可选）
# CAPTCHA_LOCAL_SOLUTION_CANDIDATES=3
# CAPTCHA_POINT_CLICK_MAX_REFRESHES=3
# CAPTCHA_MIN_AVG_SCORE=0.38
# CAPTCHA_MIN_POINT_SCORE=0.18
# CAPTCHA_MIN_SCORE_GAP=0.003

## PUSH_TYPE 余额不足提醒方式 pushplus / urlpush / wework ，默认为 None 不通知
PUSH_TYPE=None
# 余额提醒阈值
BALANCE=5.0
# pushplus token 多个用","分隔
PUSHPLUS_TOKEN=xxxxxxx,xxxxxxx,xxxxxxx
# 自定义 URL 推送
PUSH_URL="http://push.lan/notify"
# 企业微信群机器人 webhook（PUSH_TYPE=wework 时使用）
WEWORK_WEBHOOK_URL="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key"
# 拉取成功后推送户号数据汇总（wework 模式下默认 true）
WEWORK_PUSH_SUMMARY="true"

# 密码登录失败（登录次数过多等）的备选方案
LOGIN_FALLBACK='qrcode'
# 二维码的提交地址
PUSH_QRCODE_URL="http://push.lan/qrcode"

# 二维码扫描后的最多等待时间 = QR_CODE_LOGIN_WAIT_COUNT x QR_CODE_LOGIN_WAIT_TIME_INTERVAL_UNIT
# 二维码登录等待次数
QR_CODE_LOGIN_WAIT_COUNT=6
# 二维码登录等待间隔
QR_CODE_LOGIN_WAIT_TIME_INTERVAL_UNIT=10

## 日志级别（可选）
# LOG_LEVEL=INFO
# DEBUG_MODE=false
